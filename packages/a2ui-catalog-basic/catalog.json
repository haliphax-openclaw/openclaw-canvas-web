{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "A2UI Basic Catalog",
  "description": "Core first-party A2UI components",
  "type": "object",
  "components": [
    {
      "name": "Column",
      "description": "Vertical flex container for child components",
      "schema": {
        "type": "object",
        "properties": {
          "children": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Child component IDs"
          }
        }
      }
    },
    {
      "name": "Row",
      "description": "Horizontal flex container for child components",
      "schema": {
        "type": "object",
        "properties": {
          "children": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Child component IDs"
          }
        }
      }
    },
    {
      "name": "Text",
      "description": "Text display with variant styling and data binding",
      "schema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Display text (supports template interpolation)"
          },
          "variant": {
            "type": "string",
            "enum": [
              "h1",
              "h2",
              "h3",
              "h4",
              "h5",
              "h6",
              "body",
              "label"
            ],
            "default": "body",
            "description": "Text variant controlling the HTML tag"
          },
          "strokeWidth": {
            "type": "string",
            "description": "CSS text stroke width"
          }
        }
      }
    },
    {
      "name": "Button",
      "description": "Clickable button with variant styling and action support",
      "schema": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "description": "Button label text"
          },
          "variant": {
            "type": "string",
            "enum": [
              "default",
              "neutral",
              "primary",
              "secondary",
              "accent",
              "info",
              "success",
              "warning",
              "error",
              "borderless"
            ],
            "default": "default",
            "description": "Visual variant"
          },
          "href": {
            "type": "string",
            "description": "OpenClaw scheme URL for button action"
          }
        }
      }
    },
    {
      "name": "Image",
      "description": "Image display with canvas URL rewriting",
      "schema": {
        "type": "object",
        "required": ["src"],
        "properties": {
          "src": {
            "type": "string",
            "description": "Image source URL"
          },
          "alt": {
            "type": "string",
            "description": "Alt text for accessibility"
          }
        }
      }
    },
    {
      "name": "Tabs",
      "description": "Tabbed container (top, bottom, or hidden tab bar)",
      "schema": {
        "type": "object",
        "properties": {
          "tabs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string"
                },
                "child": {
                  "type": "string"
                }
              }
            },
            "description": "Tab definitions with labels and child component IDs"
          },
          "position": {
            "type": "string",
            "enum": [
              "top",
              "bottom",
              "hidden"
            ],
            "default": "top",
            "description": "Tab bar position (DaisyUI tabs-top / tabs-bottom)"
          },
          "height": {
            "type": "string",
            "default": "auto",
            "description": "Fixed height for tab content area"
          },
          "active": {
            "type": "integer",
            "default": 0,
            "description": "Initially active tab index"
          }
        }
      }
    },
    {
      "name": "Divider",
      "description": "Visual horizontal divider",
      "schema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "Slider",
      "description": "Range slider input with filter binding",
      "schema": {
        "type": "object",
        "properties": {
          "min": {
            "type": "number",
            "default": 0,
            "description": "Minimum value"
          },
          "max": {
            "type": "number",
            "default": 100,
            "description": "Maximum value"
          },
          "value": {
            "type": "number",
            "default": 0,
            "description": "Current value"
          },
          "label": {
            "type": "string",
            "description": "Optional label text"
          }
        }
      }
    },
    {
      "name": "Checkbox",
      "description": "Checkbox input with filter binding",
      "schema": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "description": "Checkbox label text"
          },
          "checked": {
            "type": "boolean",
            "default": false,
            "description": "Initial checked state"
          }
        }
      }
    },
    {
      "name": "ChoicePicker",
      "description": "A component that allows selecting one or more options from a list",
      "schema": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "description": "The label for the group of options"
          },
          "variant": {
            "type": "string",
            "enum": [
              "multipleSelection",
              "mutuallyExclusive"
            ],
            "default": "mutuallyExclusive",
            "description": "Selection mode"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          },
          "value": {
            "description": "The list of currently selected values"
          },
          "filterable": {
            "type": "boolean",
            "default": false,
            "description": "If true, displays a search input to filter options"
          }
        }
      }
    },
    {
      "name": "List",
      "description": "A layout component that renders a list of child components",
      "schema": {
        "type": "object",
        "properties": {
          "children": {
            "description": "Child component IDs"
          },
          "direction": {
            "type": "string",
            "enum": [
              "vertical",
              "horizontal"
            ],
            "default": "vertical",
            "description": "The direction in which the list items are laid out"
          },
          "align": {
            "type": "string",
            "enum": [
              "start",
              "center",
              "end",
              "stretch"
            ],
            "default": "stretch",
            "description": "Alignment of children along the cross axis"
          }
        }
      }
    },
    {
      "name": "Card",
      "description": "A container component that wraps a single child in a card layout",
      "schema": {
        "type": "object",
        "properties": {
          "child": {
            "type": "string",
            "description": "The ID of the single child component to render inside the card"
          }
        }
      }
    },
    {
      "name": "Modal",
      "description": "A dialog/modal overlay with a trigger component and content",
      "schema": {
        "type": "object",
        "properties": {
          "trigger": {
            "type": "string",
            "description": "The ID of the component that opens the modal when interacted with"
          },
          "content": {
            "type": "string",
            "description": "The ID of the component to display inside the modal"
          }
        }
      }
    },
    {
      "name": "TextField",
      "description": "Text input aligned with A2UI v0.9 basic catalog (label, value, variant, validationRegexp, checks, accessibility)",
      "schema": {
        "type": "object",
        "properties": {
          "label": {
            "description": "Field label (DynamicString: string, v0.8 literalString object, or path binding)",
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "literalString": { "type": "string" }
                },
                "required": ["literalString"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "path": { "type": "string" }
                },
                "required": ["path"],
                "additionalProperties": false
              }
            ]
          },
          "value": {
            "description": "Current value (DynamicString)",
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "literalString": { "type": "string" }
                },
                "required": ["literalString"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "path": { "type": "string" }
                },
                "required": ["path"],
                "additionalProperties": false
              }
            ]
          },
          "variant": {
            "type": "string",
            "enum": [
              "longText",
              "number",
              "shortText",
              "obscured"
            ],
            "default": "shortText",
            "description": "Input kind: longText uses a textarea; number, shortText, and obscured use input types number, text, and password"
          },
          "validationRegexp": {
            "type": "string",
            "description": "HTML pattern attribute for single-line inputs (not applied to longText textarea)"
          },
          "checks": {
            "type": "array",
            "description": "v0.9 Checkable rules: show message when condition is false (boolean or { \"path\": \"/model/valid\" } to a boolean)",
            "items": {
              "type": "object",
              "properties": {
                "condition": {
                  "description": "When false, validation fails and message is shown (boolean or { \"path\" } to a boolean in the data model)",
                  "oneOf": [
                    { "type": "boolean" },
                    {
                      "type": "object",
                      "properties": {
                        "path": { "type": "string" }
                      },
                      "required": ["path"],
                      "additionalProperties": false
                    }
                  ]
                },
                "message": {
                  "type": "string",
                  "description": "Error text when the check fails"
                }
              },
              "required": [
                "condition",
                "message"
              ]
            }
          },
          "accessibility": {
            "type": "object",
            "description": "v0.9 ComponentCommon accessibility hints",
            "properties": {
              "label": {
                "description": "Assistive name (DynamicString)",
                "oneOf": [
                  { "type": "string" },
                  {
                    "type": "object",
                    "properties": { "path": { "type": "string" } },
                    "required": ["path"],
                    "additionalProperties": false
                  }
                ]
              },
              "description": {
                "description": "Hint shown below the field (DynamicString)",
                "oneOf": [
                  { "type": "string" },
                  {
                    "type": "object",
                    "properties": { "path": { "type": "string" } },
                    "required": ["path"],
                    "additionalProperties": false
                  }
                ]
              }
            }
          },
          "placeholder": {
            "type": "string",
            "description": "Optional placeholder (renderer extension; not in v0.9 JSON schema)"
          }
        },
        "required": [
          "label"
        ]
      }
    },
    {
      "name": "Icon",
      "description": "Displays a named icon or custom SVG path",
      "schema": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "description": "The icon name (string) or an object with a custom SVG path ({ path: string })",
            "oneOf": [
              {
                "type": "string",
                "enum": [
                  "accountCircle", "add", "arrowBack", "arrowForward", "attachFile",
                  "calendarToday", "call", "camera", "check", "close",
                  "delete", "download", "edit", "event", "error",
                  "fastForward", "favorite", "favoriteOff", "folder", "help",
                  "home", "info", "locationOn", "lock", "lockOpen",
                  "mail", "menu", "moreVert", "moreHoriz", "notificationsOff",
                  "notifications", "pause", "payment", "person", "phone",
                  "photo", "play", "print", "refresh", "rewind",
                  "search", "send", "settings", "share", "shoppingCart",
                  "skipNext", "skipPrevious", "star", "starHalf", "starOff",
                  "stop", "upload", "visibility", "visibilityOff", "volumeDown",
                  "volumeMute", "volumeOff", "volumeUp", "warning"
                ]
              },
              {
                "type": "object",
                "properties": {
                  "path": { "type": "string" }
                },
                "required": ["path"]
              }
            ]
          },
          "size": {
            "type": "number",
            "description": "SVG width/height in px (renderer extension)"
          },
          "color": {
            "type": "string",
            "description": "Fill color (renderer extension)"
          }
        }
      }
    },
    {
      "name": "AudioPlayer",
      "description": "An audio player with custom controls for playback, seeking, and volume",
      "schema": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "The URL of the audio to be played"
          },
          "description": {
            "type": "string",
            "description": "A description of the audio, such as a title or summary"
          },
          "autoplay": {
            "type": "boolean",
            "default": false,
            "description": "Whether to start playing automatically"
          },
          "loop": {
            "type": "boolean",
            "default": false,
            "description": "Whether to loop the audio"
          },
          "muted": {
            "type": "boolean",
            "default": false,
            "description": "Whether the audio is initially muted"
          }
        }
      }
    },
    {
      "name": "Video",
      "description": "A video player with native controls and responsive sizing",
      "schema": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "The URL of the video to display"
          },
          "autoplay": {
            "type": "boolean",
            "default": false,
            "description": "Whether to start playing automatically"
          },
          "loop": {
            "type": "boolean",
            "default": false,
            "description": "Whether to loop the video"
          },
          "muted": {
            "type": "boolean",
            "default": false,
            "description": "Whether the video is initially muted"
          },
          "controls": {
            "type": "boolean",
            "default": true,
            "description": "Whether to show playback controls"
          },
          "poster": {
            "type": "string",
            "description": "URL of the poster image to show before playback"
          }
        }
      }
    },
    {
      "name": "DateTimeInput",
      "description": "A date/time picker input with ISO 8601 value binding",
      "schema": {
        "type": "object",
        "properties": {
          "value": {
            "type": "string",
            "description": "The selected date/time value in ISO 8601 format"
          },
          "enableDate": {
            "type": "boolean",
            "default": false,
            "description": "If true, allows the user to select a date"
          },
          "enableTime": {
            "type": "boolean",
            "default": false,
            "description": "If true, allows the user to select a time"
          },
          "min": {
            "type": "string",
            "description": "The minimum allowed date/time in ISO 8601 format"
          },
          "max": {
            "type": "string",
            "description": "The maximum allowed date/time in ISO 8601 format"
          },
          "label": {
            "type": "string",
            "description": "The text label for the input field"
          }
        }
      }
    }
  ]
}