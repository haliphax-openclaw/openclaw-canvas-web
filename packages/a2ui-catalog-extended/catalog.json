{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "A2UI Extended Catalog",
  "description": "Extended first-party A2UI components",
  "type": "object",
  "components": [
    {
      "name": "Badge",
      "description": "Inline status badge with variant styling",
      "schema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Display text for the badge"
          },
          "variant": {
            "type": "string",
            "enum": [
              "info",
              "success",
              "warning",
              "error"
            ],
            "default": "info",
            "description": "Visual variant"
          }
        }
      }
    },
    {
      "name": "Table",
      "description": "Data table with sorting and formatting support",
      "schema": {
        "type": "object",
        "properties": {
          "headers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Column header labels"
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "array"
            },
            "description": "Static row data (array of arrays)"
          },
          "sortable": {
            "type": "boolean",
            "default": false,
            "description": "Enable column sorting"
          },
          "formatters": {
            "type": "object",
            "description": "Column formatter map (column name \u2192 formatter name)"
          },
          "dataSource": {
            "type": "object",
            "description": "Data source binding for dynamic data"
          }
        }
      }
    },
    {
      "name": "Stack",
      "description": "Stacked container for overlapping child components",
      "schema": {
        "type": "object",
        "properties": {
          "children": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Child component IDs"
          }
        }
      }
    },
    {
      "name": "Spacer",
      "description": "Flexible spacer that fills available space",
      "schema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "ProgressBar",
      "description": "Progress bar with label and data binding support",
      "schema": {
        "type": "object",
        "properties": {
          "value": {
            "type": "number",
            "description": "Progress value (0-100)"
          },
          "label": {
            "type": "string",
            "description": "Optional label (supports template interpolation)"
          }
        }
      }
    },
    {
      "name": "Repeat",
      "description": "Data-driven repeater that renders a template for each row",
      "schema": {
        "type": "object",
        "properties": {
          "template": {
            "type": "object",
            "description": "Component template to repeat for each data row"
          },
          "sortable": {
            "type": "boolean",
            "default": false,
            "description": "Enable sort controls"
          },
          "sortField": {
            "type": "string",
            "description": "Field name to sort by"
          },
          "emptyText": {
            "type": "string",
            "description": "Text shown when no data rows exist"
          },
          "dataSource": {
            "type": "object",
            "description": "Binding to a surface data source; use property \"source\" (string key), same as Table/Text/Badge — not \"name\".",
            "properties": {
              "source": {
                "type": "string",
                "description": "Name of the data source (matches keys under dataSourcePush.sources / $sources)"
              }
            },
            "required": [
              "source"
            ]
          }
        },
        "required": [
          "template",
          "dataSource"
        ]
      }
    },
    {
      "name": "Wrap",
      "description": "Flex-wrap container that flows children across multiple lines",
      "schema": {
        "type": "object",
        "properties": {
          "children": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Child component IDs"
          },
          "gap": {
            "type": "string",
            "default": "8px",
            "description": "CSS gap between children (e.g. '8px', '1rem')"
          }
        }
      }
    },
    {
      "name": "Accordion",
      "description": "Collapsible accordion panels",
      "schema": {
        "type": "object",
        "properties": {
          "panels": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string"
                },
                "child": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                }
              }
            },
            "description": "Panel definitions"
          },
          "mode": {
            "type": "string",
            "enum": [
              "single",
              "multi"
            ],
            "default": "single",
            "description": "Expansion mode"
          },
          "expanded": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Initially expanded panel indices"
          }
        }
      }
    }
  ]
}